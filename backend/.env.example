# Copy this file to backend/.env and fill in your real values.
# Never commit backend/.env to Git.

# Optional Gemini model override
GEMINI_MODEL=gemini-2.5-flash

# API keys
GEMINI_API_KEY=your_gemini_api_key_here
RENTCAST_API_KEY=your_rentcast_api_key_here
# Free key from firms.modaps.eosdis.nasa.gov/api/area/ - powers the supplementary active-fire badge
NASA_FIRMS_MAP_KEY=your_firms_map_key_here

# Flask runtime
HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0

# Cache tuning (seconds)
AVM_CACHE_TTL_SEC=1800
NFHL_CACHE_TTL_SEC=86400
WHP_CACHE_TTL_SEC=86400
WIND_GUST_CACHE_TTL_SEC=86400
FHFA_HPI_CACHE_TTL_SEC=604800
REVERSE_GEO_CACHE_TTL_SEC=604800
FIRMS_CACHE_TTL_SEC=1800
